# Database
# - Use the *Pooled* connection string (contains "-pooler" in host) for DATABASE_URL in most cases.
# - For long-running dev servers or `prisma migrate`, prefer a Direct connection (no -pooler) to avoid
#   frequent "connection closed" from the pooler closing idle sockets.
# - Add connection_limit for Neon to avoid exhausting their connection quota.
# - Also set DIRECT_DATABASE_URL to your Neon "Direct connection" string (for prisma CLI commands).
DATABASE_URL=postgresql://neondb_owner:npg_TEpRci0F2quy@ep-bold-sea-aqdn8szd-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connection_limit=5&pool_timeout=30&connect_timeout=30
# DIRECT_DATABASE_URL=postgresql://neondb_owner:xxx@ep-bold-sea-aqdn8szd.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Auth (generate with: openssl rand -base64 32)
NEON_AUTH_COOKIE_SECRET=XHVnHojXwC1376WD4ysC/0ZtmKX9V6vBvy/zaQ9yPIo=

