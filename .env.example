# Database
DATABASE_URL=postgresql://user:password@host:5432/fabrio
# Direct connection for Prisma migrations (Neon: use the non-pooled URL)
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/fabrio

# Auth (generate with: openssl rand -base64 32)
NEON_AUTH_COOKIE_SECRET=your-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile Money (Uganda)
NEXT_PUBLIC_MOBILE_MONEY_BUSINESS_NAME=Fabrio Hardware
NEXT_PUBLIC_MTN_MERCHANT_NUMBER=0771234567
NEXT_PUBLIC_AIRTEL_MERCHANT_NUMBER=0701234567

# MTN MoMo API (optional — enables live API payments)
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_SUBSCRIPTION_KEY=
# MTN_MOMO_ENVIRONMENT=sandbox
# MTN_MOMO_WEBHOOK_SECRET=generate-a-random-secret
# NEXT_PUBLIC_MTN_MOMO_API_ENABLED=false

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=Fabrio Hardware <orders@yourdomain.com>

# Error monitoring (Sentry — https://sentry.io)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# E2E tests (optional overrides)
# E2E_CUSTOMER_EMAIL=john@company.com
# E2E_CUSTOMER_PASSWORD=customer
# E2E_ADMIN_EMAIL=admin@fabrio.com
# E2E_ADMIN_PASSWORD=admin123