# Database
DATABASE_URL=postgresql://user:password@host:5432/fabrio

# Auth (generate with: openssl rand -base64 32)
NEON_AUTH_COOKIE_SECRET=your-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile Money (Uganda)
NEXT_PUBLIC_MOBILE_MONEY_BUSINESS_NAME=Fabrio Hardware
